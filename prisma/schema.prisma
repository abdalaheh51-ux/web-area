generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // <-- هذا السطر مهم جداً لـ Supabase
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String
  avatar       String?
  role         String   @default("user")
  sessionToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id            String   @id @default(cuid())
  email         String
  name          String?
  needsStore    Boolean  @default(false)
  needsERP      Boolean  @default(false)
  needsLanding  Boolean  @default(false)
  solutionType  String?
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VisitorComment {
  id         String   @id @default(cuid())
  name       String?
  comment    String
  rating     Int      @default(5)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isApproved Boolean  @default(false)
}

model ProjectRequest {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  industry        String
  description     String?
  referenceSites  String
  features        String
  visualStyle     String?
  budget          String?
  timeline        String?
  contactMethod   String
  name            String
  email           String
  phone           String?
  bestTime        String?
  status          String   @default("new")
  adminNotes      String?
}

model PortfolioItem {
  id          String   @id @default(cuid())
  order       Int      @default(0)
  name        String
  nameEn      String   @default("")
  description String   @default("")
  descriptionEn String @default("")
  category    String   @default("")
  technologies String  @default("")
  problem     String   @default("")
  problemEn   String   @default("")
  solution    String   @default("")
  solutionEn  String   @default("")
  result      String   @default("")
  resultEn    String   @default("")
  imageUrl    String?
  gallery1    String?
  gallery2    String?
  gallery3    String?
  externalUrl String?
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
