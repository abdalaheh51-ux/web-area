# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/webarea?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/webarea?schema=public"

# ============================================
# Admin Account Setup (required for admin access)
# ============================================
# IMPORTANT: These credentials are NEVER committed to Git/GitHub.
# They must be set only in your local .env file or server environment variables.
# After running `bun run db:seed-admin`, the admin account will be created in the database.
# The credentials will NOT appear anywhere in your code or repository.

ADMIN_EMAIL="your-admin-email@example.com"
ADMIN_PASSWORD="change-this-to-a-strong-password"
ADMIN_NAME="Admin"

# ============================================
# Application Settings
# ============================================
NODE_ENV="development"
PORT=3000
